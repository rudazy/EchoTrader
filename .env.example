# --- LLM (default: Anthropic) ---
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- CoinMarketCap (MCP or REST) ---
# MCP endpoint: https://mcp.coinmarketcap.com/mcp
# Header: X-CMC-MCP-API-KEY
CMC_API_KEY=your_coinmarketcap_api_key
CMC_MCP_URL=https://mcp.coinmarketcap.com/mcp

# x402 autonomous payment (optional — pays per request in USDC on Base)
X402_WALLET_PRIVATE_KEY=
X402_ENABLED=false

# --- Trust Wallet Agent Kit (TWAK) ---
TWAK_ACCESS_ID=your_twak_access_id
TWAK_HMAC_SECRET=your_twak_hmac_secret
TWAK_WALLET_PASSWORD=your_wallet_password
TWAK_CHAIN=bsc
TWAK_QUOTE_AMOUNT=10

# --- BNB Agent SDK (optional on-chain identity) ---
BNB_AGENT_PRIVATE_KEY=
BNB_CHAIN_ID=56

# --- EchoTrader guardrails ---
DRY_RUN=true
MAX_DAILY_DRAWDOWN_PCT=3.0
MAX_POSITION_SIZE_PCT=5.0
DEFAULT_SLIPPAGE_PCT=1.0
COOLDOWN_MINUTES=60
TOKEN_ALLOWLIST=BNB,ETH,USDT,USDC

# --- Orchestrator ---
LOOP_INTERVAL_SECONDS=300
LOG_LEVEL=INFO

# --- Dashboard API (optional) ---
# Comma-separated frontend origins for CORS
CORS_ORIGINS=https://echotrader.vercel.app

# --- Railway deploy ---
# After `railway login`, run: scripts\railway-deploy.cmd
# Or set vars manually: railway variable set ANTHROPIC_API_KEY=... CMC_API_KEY=...